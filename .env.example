# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL (for OG tags, metadata)
NEXT_PUBLIC_BASE_URL=https://pollpromise.com

# Salt for IP hashing (use a random secret!)
IP_SALT=your-random-secret-here

# Cron job secret (must match Vercel Environment Variables)
CRON_SECRET=your-cron-secret-here
